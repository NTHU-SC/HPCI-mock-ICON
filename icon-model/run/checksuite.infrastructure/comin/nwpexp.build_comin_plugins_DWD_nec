#
# Pre-test script for ComIn plugins
#
# This script is run prior to the actual test jobs that utilize ComIn plugins.
# It builds the example plugins for the DWD NEC platform, as well as the vector hosts and the vector engine.

set -ex

for builddir in "${PBS_O_WORKDIR}/../host" "${PBS_O_WORKDIR}/../vector"; do
  (
    cd "${builddir}"
    eval "set +x; $(make env) set -x"
    cmake -DCOMIN_ENABLE_EXAMPLES=ON externals/comin/build
    make -C externals/comin/build --jobs=24 --keep-going --no-print-directory --output-sync=target VERBOSE=1
  )
done
