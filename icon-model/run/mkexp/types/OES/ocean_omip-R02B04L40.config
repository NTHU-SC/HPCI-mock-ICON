#
# Test setup for OMIP
#

VERSION_ = $$Id$$

INITIAL_DATE = 2010-01-01T00:00:00Z
FINAL_DATE = 2010-02-01T00:00:00Z
INTERVAL = P1M

WITH_ATMO = false
WITH_LAND = false

ATMO_GRID_TYPE =
ATMO_GRID_ID =
ATMO_BLOCK_SIZE =
ATMO_TIME_STEP =
ATMO_RADIATION_TIME_STEP =

OCEAN_GRID_TYPE = R02B04
OCEAN_GRID_ID = 0036
OCEAN_TIME_STEP = PT1H
OCEAN_BLOCK_SIZE = 16

OCEAN_INPUT_SUBDIR = ICON/oes/input/r0006

COUPLER_TIME_STEP =

[namelists]
  [[NAMELIST_oce]]
    [[[dbg_index_nml]]]
      dbg_lat_in = 30.0
      dbg_lon_in = -30.0
      idbg_elev = 5
      idbg_mxmn = 0
      idbg_slev = 1
      idbg_val = 0
      str_mod_tst = all
    [[[dynamics_nml]]]
    [[[grid_nml]]]
      dynamics_grid_filename = icon_grid_O.nc
      use_dummy_cell_closure = true
      use_duplicated_connectivity = false
    [[[io_nml]]]
      lkeep_in_sync = true
      restart_file_type = 5
      restart_write_mode = joint procs multifile
      write_last_restart = true
    [[[ocean_diagnostics_nml]]]
      diagnose_age = false
      diagnose_for_heat_content = true
      diagnose_for_horizontalvelocity = false
      diagnose_for_tendencies = true
      diagnose_green = false
      diagnostics_level = 1
      eddydiag = false
    [[[ocean_dynamics_nml]]]
      cfl_check = false
      cfl_write = false
      dzlev_m = 12., 10., 10., 10., 10., 10., 13., 15., 20., 25., 30., 35., 40., 45., 50., 55., 60., 70., 80., 90., 100., 110., 120., 130., 140., 150., 170., 180., 190., 200., 220., 250., 270., 300., 350., 400., 450., 500., 500., 600.
      fast_performance_level = 200
      i_bc_veloc_bot = 1
      i_bc_veloc_top = 1
      l_edge_based = false
      l_lhs_direct = false
      l_max_bottom = true
      l_partial_cells = false
      minverticallevels = 2
      n_zlev = 40
      select_lhs = 1
      select_solver = 4
      solver_firstguess = 2
      solver_max_iter_per_restart = 14
      solver_max_restart_iterations = 100
      solver_tolerance = 1.0E-9
      use_absolute_solver_tolerance = true
      use_continuity_correction = true
      vert_cor_type = 1
    [[[ocean_forcing_nml]]]
      atm_pressure_included_in_icedyn = false
      atm_pressure_included_in_ocedyn = false
      forcing_fluxes_type = 1
      forcing_frequency = 86400.0
      forcing_timescale = 365
      forcing_windstress_u_type = 1
      forcing_windstress_v_type = 1
      iforc_oce = 12
      init_oce_relax = 1
      jerlov_atten = 0.08
      jerlov_bluefrac = 0.36
      limit_elevation = true
      limit_seaice = true
      lswr_jerlov = true
      para_surfrelax_salt = 3.0
      para_surfrelax_temp = 1.0
      seaice_limit = 6.0
      tides_mod = 1
      type_surfrelax_salt = 1
      type_surfrelax_temp = 0
      use_tides = false
    [[[ocean_gentmcwilliamsredi_nml]]]
      gmredi_combined_diagnostic = false
      gmredi_configuration = 1
      gmredi_usesrelativemaxslopes = false
      include_slope_squared_implicit = true
      k_tracer_dianeutral_parameter = 0.0
      k_tracer_gm_kappa_parameter = 1000.0
      k_tracer_isoneutral_parameter = 1000.0
      revert_vertical_recon_and_transposed = true
      s_d = 0.0001
      s_max = 1.0e-3
      slope_calc_via_temperture_salinity = true
      switch_off_diagonal_vert_expl = true
      switch_on_redi_balance_diagonstic = false
      switch_on_tapering_horizontal_diffusion = true
      tapering_scheme = 1
    [[[ocean_horizontal_diffusion_nml]]]
      biharmonicviscosity_background = 0.0
      biharmonicviscosity_reference = 2.7e-2
      biharmonicviscosity_scaling = 4
      harmonicviscosity_background = 0.0
      harmonicviscosity_reference = 0.0
      harmonicviscosity_scaling = 1
      laplacian_form = 1
      salinity_horizontaldiffusion_background = 0.0
      salinity_horizontaldiffusion_reference = 0
      temperature_horizontaldiffusion_background = 0.0
      temperature_horizontaldiffusion_reference = 0
      tracerhorizontaldiffusion_scaling = 1
      velocitydiffusion_order = 2
    [[[ocean_physics_nml]]]
      i_sea_ice = 1
    [[[ocean_tracer_transport_nml]]]
      fct_high_order_flux = 5
      fct_limiter_horz = 100
      fct_low_order_flux = 1
      flux_calculation_horz = 5
      flux_calculation_vert = 7
      no_tracer = 2
      threshold_min_t = -2.0
    [[[ocean_vertical_diffusion_nml]]]
      alpha_tke = 30.0
      c_eps = 0.7
      c_k = 0.1
      cd = 3.75
      clc = 0.15
      kappam_max = 100.0
      kappam_min = 0.0
      l_lc = true
      mxl_min = 1.d-8
      only_tke = true
      tke_min = 1.d-6
      tke_mxl_choice = 2
      tke_surf_min = 1.d-4
      use_lbound_dirichlet = false
      use_ubound_dirichlet = false
      vert_mix_type = 2
    [[[output_nml P1D_kin]]]
      file_interval = P50Y
      filename_format = <output_filename>_<datetime2>
      filetype = 5
      include_last = false
      m_levels = "1,12,30"
      ml_varlist = zos, mlotst, hi, hs, conc, ice_u, ice_v, u, v, to, so, kin, vort
      mode = 1
      operation = mean
      output_end = $FINAL_DATE
      output_filename = ${EXP_ID}_P1D_kin
      output_grid = true
      output_interval = P1D
      output_start = $INITIAL_DATE
    [[[output_nml P1M_mon]]]
      file_interval = P50Y
      filename_format = <output_filename>_<datetime2>
      filetype = 5
      include_last = false
      ml_varlist = group:ocean_monitor
      mode = 1
      operation = mean
      output_end = $FINAL_DATE
      output_filename = ${EXP_ID}_P1M_mon
      output_grid = true
      output_interval = P1M
      output_start = $INITIAL_DATE
    [[[output_nml P1M_qps]]]
      file_interval = P50Y
      filename_format = <output_filename>_<datetime2>
      filetype = 5
      include_last = false
      ml_varlist = to, so, tke, u, v, zos, hi, hs, conc, mlotst, verticallyTotal_mass_flux_e, ice_u, ice_v, zos_square, HeatFlux_Total, FrshFlux_Runoff, FrshFlux_Precipitation, FrshFlux_Evaporation, FrshFlux_TotalOcean, FrshFlux_VolumeIce, totalsnowfall, FrshFlux_VolumeTotal, group:ocean_moc
      mode = 1
      operation = mean
      output_end = $FINAL_DATE
      output_filename = ${EXP_ID}_P1M_qps
      output_grid = true
      output_interval = P1M
      output_start = $INITIAL_DATE
    [[[output_nml fx]]]
      file_interval = P50Y
      filename_format = <output_filename>_<datetime2>
      filetype = 5
      include_last = false
      ml_varlist = lsm_ctr_c, lsm_c, lsm_e, surface_cell_sea_land_mask, surface_edge_sea_land_mask, surface_vertex_sea_land_mask, vertex_bottomLevel, basin_c, regio_c, bottom_thick_c, bottom_thick_e, column_thick_c, column_thick_e, wet_c, wet_e, wet_halo_zero_c, wet_halo_zero_e, prism_thick_c, invConstantPrismThickness, prism_volume, prism_thick_e, prism_thick_flat_sfc_c, prism_thick_flat_sfc_e, inverse prism_thick_c, prism_center_dist_c, constantPrismCenters_Zdistance, constantPrismCenters_invZdistance, inv_prism_thick_e, inv_prism_center_dist_c, inv_prism_center_dist_e, depth_CellMiddle
      mode = 1
      output_end = $INITIAL_DATE
      output_filename = ${EXP_ID}_fx
      output_grid = true
      output_interval = P1000Y
      output_start = $INITIAL_DATE
    [[[parallel_nml]]]
      l_fast_sum = true
      nblocks_c = 0
      nproma = 32
      num_io_procs = 1
      num_prefetch_proc = 0
      num_restart_procs = 1
      p_test_run = false
      pio_type = 1
    [[[run_nml]]]
      activate_sync_timers = true
      debug_check_level = 0
      modeltimestep = PT1H
      msg_timestamp = false
      output = nml
      profiling_output = 1
      restart_filename = ${EXP_ID}_restart_oce_<rsttime>.mfr
      timers_level = 10
    [[[sea_ice_nml]]]
      albedow_sim = 0.10
      albi = 0.70
      albim = 0.65
      albs = 0.80
      albsm = 0.65
      cd_io = 5.5e-3
      delta_min = 2.0e-09
      i_ice_dyn = 1
      i_ice_therm = 1
      initialize_seaice_fromfile = true
      leadclose_1 = 0.25
      leadclose_2n = 0.
  [[icon_master.namelist]]
    [[[master_time_control_nml]]]
      experimentstartdate = $INITIAL_DATE
[files]
  [[ocean]]
    [[[grids]]]
      ocean-flux.nc = R2B4_ocean-flux.nc
      icon_grid_O.nc = R2B4_ocean-grid.nc
      ocean-relax.nc = R2B4_ocean-relax.nc
[jobs]
  [[run_start]]
    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[master_nml]]]]]
          lrestart =
      [[[[NAMELIST_oce]]]]
        [[[[[ocean_initialconditions_nml]]]]]
          initial_temperature_type = 1 # read T from 'initial_state.nc'
          initial_salinity_type = 1 # read S from 'initial_state.nc'
    [[[files]]]
      [[[[ocean]]]]
        [[[[[restart_data]]]]]
          restart_oce_DOM01_data.nc =
        [[[[[restart]]]]]
          restart_oce_DOM01.nc =
        [[[[[grids]]]]]
          initial_state.nc = R2B4L40_oras5-2010-01-01.nc
