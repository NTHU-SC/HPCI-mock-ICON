      ic_filename = ic_land_soil_DOM04.nc
      l_dynsnow = true
      l_freeze = true
      l_heat_cap_dyn = false
      l_heat_cap_map = false
      l_heat_cond_dyn = false
      l_heat_cond_map = false
      l_snow = true
      l_soil_texture = false
      l_supercool = false
    [[[jsb_turb_nml]]]
      bc_filename = bc_land_phys_DOM04.nc
      ic_filename = ic_land_soil_DOM04.nc
      max_ini_rough_m = 1.0
  [[icon_master.namelist]]
    .remove = jsb_model_nml
    [[[jsb_model_nml]]]
      model_id = %{id}
      model_name = JSBACH DOM0%{id}
      model_namelist_filename = NAMELIST_lnd_d%{id}
      model_shortname = jsb_d%{id}
    [[[jsb_model_nml 1]]]
    [[[jsb_model_nml 2]]]
    [[[jsb_model_nml 3]]]
    [[[jsb_model_nml 4]]]
    [[[master_time_control_nml]]]
      calendar = proleptic gregorian
      checkpointtimeintval = PT8M
      experimentstartdate = $INITIAL_DATE
      experimentstopdate = $FINAL_DATE
      restarttimeintval = $INTERVAL
    [[[time_nml]]]
      is_relative_time = false

[files]

  [[atmosphere]]
    [[[model]]]
      [[[[data]]]]
        .sub_dir = data
        lsdata.nc =
        ECHAM6_CldOptProps.nc =
        rrtmgp-cloud-optics-coeffs-lw.nc = ECHAM6_CldOptProps_rrtmgp_lw.nc
        rrtmgp-cloud-optics-coeffs-sw.nc = ECHAM6_CldOptProps_rrtmgp_sw.nc
      [[[[rrtmgp]]]]
        .sub_dir = data
        coefficients_lw.nc = rrtmgp-gas-lw-g128.nc
        coefficients_sw.nc = rrtmgp-gas-sw-g112.nc
    [[[independent]]]
      .sub_dir = common
      bc_greenhouse_gases.nc = greenhouse_gases/greenhouse_$SCENARIO.nc
      [[[[solar_irradiance]]]]
        .sub_dir = solar_radiation
        bc_solar_irradiance_sw_b14.nc = swflux_14band_cmip6_1850-2299-v3.2.nc
    [[[mapped]]]
      .sub_dir = $ATMO_GRID_ID/lamnest/r0100
      # Remove single domain data
      icon_grid_G.nc =
      # Add data for all domains
      global_160km_DOM01.nc = .
      Tropical_Atlantic_80km_DOM02.nc = .
      Tropical_Atlantic_40km_DOM03.nc = .
      Tropical_Atlantic_40km_DOM04.nc = .
      [[[[initial]]]]
        ifs2icon_DOM01.nc = ic_atmo_DOM01.nc
        ifs2icon_DOM02.nc = ic_atmo_DOM02.nc
        ifs2icon_DOM03.nc = ic_atmo_DOM03.nc
        ifs2icon_DOM04.nc = ic_atmo_DOM04.nc
      [[[[ozone]]]]
        bc_ozone_DOM01.nc = .
        bc_ozone_DOM02.nc = .
        bc_ozone_DOM03.nc = .
        bc_ozone_DOM04.nc = .
      [[[[ocean_surface]]]]
        bc_sic_DOM01.nc = .
        bc_sic_DOM02.nc = .
        bc_sic_DOM03.nc = .
        bc_sic_DOM04.nc = .
        bc_sst_DOM01.nc = .
        bc_sst_DOM02.nc = .
        bc_sst_DOM03.nc = .
        bc_sst_DOM04.nc = .
      [[[[aerosols]]]]
        bc_aeropt_kinne_lw_b16_coa_DOM01.nc = .
        bc_aeropt_kinne_lw_b16_coa_DOM02.nc = .
        bc_aeropt_kinne_lw_b16_coa_DOM03.nc = .
        bc_aeropt_kinne_lw_b16_coa_DOM04.nc = .
        bc_aeropt_kinne_sw_b14_coa_DOM01.nc = .
        bc_aeropt_kinne_sw_b14_coa_DOM02.nc = .
        bc_aeropt_kinne_sw_b14_coa_DOM03.nc = .
        bc_aeropt_kinne_sw_b14_coa_DOM04.nc = .
        bc_aeropt_kinne_sw_b14_fin_DOM01.nc = .
        bc_aeropt_kinne_sw_b14_fin_DOM02.nc = .
        bc_aeropt_kinne_sw_b14_fin_DOM03.nc = .
        bc_aeropt_kinne_sw_b14_fin_DOM04.nc = .
    [[[restart]]]
      multifile_restart_atm.mfr = ${EXP_ID}_restart_atm_$${start_stamp}Z.mfr
      restart_atm_DOM01.nc =

  [[land]]
    [[[mapped]]]
      .sub_dir = $ATMO_GRID_ID/lamnest/r0100
      # Remove single domain data
      bc_land_frac.nc =
      bc_land_phys.nc =
      bc_land_soil.nc =
      bc_land_sso.nc =
      ic_land_soil.nc =
      # Add data for all domains
      bc_land_frac_DOM01.nc = .
      bc_land_frac_DOM02.nc = .
      bc_land_frac_DOM03.nc = .
      bc_land_frac_DOM04.nc = .
      bc_land_phys_DOM01.nc = .
      bc_land_phys_DOM02.nc = .
      bc_land_phys_DOM03.nc = .
      bc_land_phys_DOM04.nc = .
      bc_land_soil_DOM01.nc = .
      bc_land_soil_DOM02.nc = .
      bc_land_soil_DOM03.nc = .
      bc_land_soil_DOM04.nc = .
      bc_land_sso_DOM01.nc = .
      bc_land_sso_DOM02.nc = .
      bc_land_sso_DOM03.nc = .
      bc_land_sso_DOM04.nc = .
      ic_land_soil_DOM01.nc = .
      ic_land_soil_DOM02.nc = .
      ic_land_soil_DOM03.nc = .
      ic_land_soil_DOM04.nc = .

[jobs]
  # Initialize atmosphere from standard climatology, no spin-up
  [[run_start]]
    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[jsb_control_nml]]]]]
          restart_jsbach =
        [[[[[master_nml]]]]]
          lrestart =
    [[[files]]]
      [[[[atmosphere]]]]
        [[[[[restart_data]]]]]
          .hide = true
        [[[[[restart]]]]]
          .hide = true
  # Minimal testing resources
  [[run]]
    nodes = 1
    time_limit = 00:05:00
