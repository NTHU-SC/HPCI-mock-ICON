    [[[interpol_nml]]]
    [[[io_nml]]]
      itype_pres_msl = 4
      lnetcdf_flt64_output = false
      restart_file_type = 5
      restart_write_mode = joint procs multifile
    [[[nonhydrostatic_nml]]]
      damp_height = 44000.
      divdamp_fac = 0.004
      divdamp_order =
      divdamp_trans_end = 17500
      divdamp_trans_start = 12500
      divdamp_type = 32
      exner_expol = 0.333
      hbot_qvsubstep = 16000.
      htop_moist_proc = 22500.
      iadv_rhotheta = 2
      igradp_method = 3
      itime_scheme = 4
      ivctype = 2
      l_zdiffu_t = true
      ndyn_substeps = 5
      rayleigh_coeff = 1
      thhgtd_zdiffu = 125.
      thslp_zdiffu = 0.02
      vwind_offctr = 0.2
    [[[output_nml atm_2d_ml]]]
      file_interval = PT2M
      filename_format = <output_filename>_DOM<physdom>_<datetime2>
      filetype = 5
      ml_varlist = psl, ts, clt, pr, prw, cllvi, clivi, hfls, hfss, evspsbl, tauu, tauv, sfcwind, tas, ps, cosmu0, sic, sit, prlr, prls, qgvi, qrvi, qsvi, uas, vas, dew2, pr_rain, pr_ice, pr_snow, pr_grpl
      mode = 1
      operation = mean
      output_end = $FINAL_DATE
      output_filename = ${EXP_ID}_atm_2d_ml
      output_interval = PT2M
      output_start = $INITIAL_DATE
    [[[parallel_nml]]]
      io_proc_chunk_size = 46
      io_process_stride = 8
      nblocks_c = 0
      nproma = 32
      nproma_sub = 32
      num_io_procs = 1
      num_restart_procs = 0
    [[[run_nml]]]
      activate_sync_timers = true
      iforcing = 2
      ldynamics = true
      ltestcase = false
      ltransport = true
      modeltimestep = PT2M
      msg_level = 18
      num_lev = 90
      output = nml
      profiling_output = 1
      restart_filename = ${EXP_ID}_restart_atm_<rsttime>.mfr
      timers_level = 10
    [[[sea_ice_nml]]]
      albedow_sim = 0.10
      albi = 0.70
      albim = 0.68
      albs = 0.81
      albsm = 0.77
      cd_io = 5.5e-3
      delta_min = 2.0e-09
      evp_rheol_steps = 240
      i_ice_dyn = 1
      i_ice_therm = 1
      leadclose_1 = 0.25
      leadclose_2n = 0.666
      luse_replacement_pressure = true
    [[[sleve_nml]]]
      decay_exp = 1.2
      decay_scale_1 = 4000.
      decay_scale_2 = 2500.
      flat_height = 16000.
      htop_thcknlimit = 14000.
      max_lay_thckn = 400.
      min_lay_thckn = 25.
      stretch_fac = 0.9
      top_height = 75000.
    [[[transport_nml]]]
