#
# Atmosphere Nest test experiment for Buildbot in R2B4
#

VERSION_ = $$Id$$

SCENARIO = ssp370

# Atmosphere setup
ATMO_GRID_ID = 0049
ATMO_GRID_TYPE = R02B04
ATMO_LEVELS = 90

ATMO_TIME_STEP = PT2M
ATMO_RADIATION_TIME_STEP = PT8M

# Switch off ocean
WITH_OCEAN = false
WITH_OBGC = false

# Variables that needs to be unset to avoid issues with DEFAULT.config
OCEAN_GRID_TYPE =
OCEAN_TIME_STEP =
OCEAN_BLOCK_SIZE =
OCEAN_GRID_ID =
OBGC_EUPHOTIC_LEVELS =
COUPLER_TIME_STEP =

# Time control
INITIAL_DATE = 1979-01-01T00:00:00Z
FINAL_DATE = 1979-01-01T00:16:00Z
INTERVAL = PT16M

# Output control
OUTPUT_INTERVAL = PT2M
FILE_INTERVAL   = PT2M

