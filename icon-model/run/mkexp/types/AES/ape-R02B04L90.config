# ------------------------------------------
# Aqua Planet Experiment (APE) - Sapphire Configuration
# author_list="Angel Peinado, MPIM"
# ------------------------------------------
# This file describes an aqua planet experiment based with Sapphire configuration.
# It is based in the APE protocol:
# - constant zonal SST, no land, no sea icem, no aerosol
# - parameterization used Radiation, Turbulence and Micro-physics scheme
# - well mixed greenhouse gases CO2
# - constant O3 concentration
#=============================================================================

VERSION_ = $$Id: run/mkexp/types/aes_ape.config 8 2025-07-08 m300901 $$

# APE config
APE_SST = sst_qobs
APE_EXP_TYPE = APE_aes

# Atmosphere setup
ATMO_GRID_ID = 0013
ATMO_GRID_TYPE = R02B04
ATMO_LEVELS = 90

ATMO_TIME_STEP = PT10M
ATMO_RADIATION_TIME_STEP = PT20M
ATMO_DYNAMICS_SUBSTEPS = 5
ATMO_BLOCK_SIZE = 32

ATMO_USE_TMX = true

# Land setup
WITH_LAND = false

# Ocean setup
WITH_OCEAN = false

# Variables that needs to be unset to avoid issues with DEFAULT.config
LAND_USECASE = jsbach_lite
LAND_WITH_LAKES = false

OCEAN_GRID_TYPE =
OCEAN_BLOCK_SIZE =
OCEAN_TIME_STEP =
OCEAN_GRID_ID =
OBGC_EUPHOTIC_LEVELS =
COUPLER_TIME_STEP =

# Time control
CALENDAR            = proleptic gregorian

# Output control
OUTPUT_INTERVAL = P1D
FILE_INTERVAL   = P1M

[namelists]
  [[icon_master.namelist]]
    [[[master_nml]]]
      lrestart = false
    [[[master_time_control_nml]]]
      calendar = $CALENDAR
      experimentstartdate = $INITIAL_DATE
  [[NAMELIST_lnd]]
  [[NAMELIST_atm]]
   .remove += dbg_index_nml, extpar_nml, initicon_nml, output_nml atm_vgrid, output_nml atm_dbg, output_nml atm_mon, output_nml lnd_mon
   [[[parallel_nml]]]
      iorder_sendrecv = 3
      num_io_procs = 2
      num_prefetch_proc =
      num_restart_procs = 1
      pio_type =
      nblocks_c = 0
      nproma_sub = $ATMO_BLOCK_SIZE
      io_proc_chunk_size = 46
      io_process_stride = 8
    [[[run_nml]]]
      ltestcase = true
      activate_sync_timers = true
      profiling_output = 1
      msg_level = 15
      timers_level = 10
    [[[extpar_nml]]]
      itopo = 0
    [[[aes_cov_nml]]]
      aes_cov_config(1)%cqx = 1.e-6
    [[[aes_phy_nml]]]
      aes_phy_config(1)%dt_mig = $ATMO_TIME_STEP
      aes_phy_config(1)%dt_rad = $ATMO_RADIATION_TIME_STEP
      aes_phy_config(1)%dt_vdf = $ATMO_TIME_STEP
      aes_phy_config(1)%lamip = false
      aes_phy_config(1)%lice = false
      aes_phy_config(1)%ljsb = false
      aes_phy_config(1)%llake = false
      aes_phy_config(1)%lmlo = false
    [[[aes_rad_nml]]]
      aes_rad_config(1)%cecc = 0.0
      aes_rad_config(1)%cobld = 0.0
      aes_rad_config(1)%irad_aero = 0
      aes_rad_config(1)%irad_cfc11 = 0
      aes_rad_config(1)%irad_cfc12 = 0
      aes_rad_config(1)%irad_ch4 = 0
      aes_rad_config(1)%irad_co2 = 2
      aes_rad_config(1)%irad_h2o = 1
      aes_rad_config(1)%irad_n2o = 0
      aes_rad_config(1)%irad_o2 = 0
      aes_rad_config(1)%irad_o3 = 4
      aes_rad_config(1)%isolrad = 2
      aes_rad_config(1)%l_orbvsop87 = false
    [[[aes_vdf_nml]]]
      aes_vdf_config(1)%pr0 = 0.7
      aes_vdf_config(1)%turb = 2
      #aes_vdf_config(1)%use_tmx = false
    [[[initicon_nml]]]
      pinit_amplitude = 0.
      pinit_seed = -1
    [[[interpol_nml]]]
      rbf_scale_mode_ll = 1
    [[[io_nml]]]
      itype_pres_msl = 4
      lnetcdf_flt64_output = false
      restart_file_type = 5
      restart_write_mode = joint procs multifile
      write_last_restart = true
    [[[nh_testcase_nml]]]
      ape_sst_case = $APE_SST
      nh_test_name = $APE_EXP_TYPE
      zp_ape = 101325
      ztmc_ape = 25.006
    [[[nonhydrostatic_nml]]]
      damp_height = 44000.
      divdamp_fac = 0.004
      divdamp_order = 24
      divdamp_trans_end = 17500
      divdamp_trans_start = 12500
      divdamp_type = 32
      exner_expol = 0.333
      hbot_qvsubstep = 16000.
      htop_moist_proc = 22500.
      iadv_rhotheta = 2
      igradp_method = 3
      itime_scheme = 4
      ivctype = 2
      l_zdiffu_t = true
      ndyn_substeps = $ATMO_DYNAMICS_SUBSTEPS
      rayleigh_coeff = 1.0
      thhgtd_zdiffu = 125.
      thslp_zdiffu = 0.02
      vwind_offctr = 0.2
    [[[sleve_nml]]]
      decay_exp = 1.2
      decay_scale_1 = 4000.
      decay_scale_2 = 2500.
      flat_height = 22500.
      htop_thcknlimit = 14000.
      max_lay_thckn = 400.
      min_lay_thckn = 25.
      stretch_fac = 0.9
      top_height = 75000.
    [[[transport_nml]]]
      ihadv_tracer = 20, 20, 20, 20, 20, 20
      itype_hlimit = 3, 4, 4, 4, 4, 4
      ivadv_tracer = 3, 3, 3, 3, 3, 3
      tracer_names = hus, clw, cli, qr, qs, qg
    # Define output files
    # -------------------
    # Default settings for 'output_nml *'
    [[[output_nml]]]
      filename_format = <output_filename>_<datetime2>
      filetype = 5
      include_last = false
      output_grid = false
      output_start = $INITIAL_DATE
      operation = mean
      file_interval = ${FILE_INTERVAL}
      output_interval = ${OUTPUT_INTERVAL}

    [[[output_nml atm_2d_P1D_ml]]]
      ml_varlist = ps, tas, cptgzvi, rsdt, rsut, rsutcs, rlut, rlutcs, rsds, rsdscs, rlds, rldscs, rsus, rsuscs, rlus, hfls, hfss, clt, pr, prw, cllvi, clivi, evspsbl, qgvi, qrvi, qsvi, qv2m, tauu, tauv, sfcwind, uas, vas
      output_filename = ${EXP_ID}_atm_2d_P1D

    [[[output_nml atm_3d_P1D_ml]]]
      ml_varlist = pfull, ta, rho, ua, va, wa, hus, cli, clw, qr, qg, qs, phalf, rsd, rsu, rld, rlu
      output_filename = ${EXP_ID}_atm_3d_P1D
      m_levels = 30...(nlev)

[files]

  [[atmosphere]]
    [[[restart_data]]]
      .hide = true
    [[[restart]]]
      .hide = true

    [[[model]]]
      [[[[data]]]]
        .sub_dir = data
        lsdata.nc =
        ECHAM6_CldOptProps.nc =
        rrtmgp-cloud-optics-coeffs-lw.nc = ECHAM6_CldOptProps_rrtmgp_lw.nc
        rrtmgp-cloud-optics-coeffs-sw.nc = ECHAM6_CldOptProps_rrtmgp_sw.nc
      [[[[rrtmgp]]]]
        .sub_dir = data
        coefficients_lw.nc = rrtmgp-gas-lw-g128.nc
        coefficients_sw.nc = rrtmgp-gas-sw-g112.nc
   [[[independent]]]
      .sub_dir = common
      .method = ln -s
      bc_greenhouse_gases.nc = greenhouse_gases/greenhouse_historical_plus.nc
   [[[mapped]]]
      .method = ln -s
      [[[[ozone]]]]
        .sub_dir = ozone/r0002
        bc_ozone.nc = bc_ozone_ape.nc
  [[land]]
    [[[mapped]]]
      .sub_dir = $ATMO_GRID_ID/land/r0002
    [[[hydro]]]
      .hide = true

# Initialize atmosphere only from standard climatology
[jobs]
  .remove += clean, intake, mon, mon_index, post, run, mon_log
  [[run_start]]
    .trigger =
    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[master_nml]]]]]
          lrestart =
    [[[files]]]
      [[[[atmosphere]]]]
        [[[[[restart_data]]]]]
          .hide = true
        [[[[[restart]]]]]
          .hide = true
