#
# Radiative convective equilibrium (RCE) configuration for AES physics
#
# Follows the small domain configuration of RCEMIP see Wing et al., 2018.
#

VERSION_ = $$Id: run/mkexp/types/rce.config 1 2025-07-09 13:40:24Z m301047 $$

ATMO_GRID_TYPE =
ATMO_GRID_ID =

OCEAN_GRID_TYPE =
OCEAN_BLOCK_SIZE =
OCEAN_TIME_STEP =
OCEAN_GRID_ID =

COUPLER_TIME_STEP =

WITH_LAND = false
WITH_OCEAN = false

LAND_USECASE = jsbach_lite
LAND_WITH_LAKES = false

CALENDAR = 360 day year

INITIAL_DATE = 2025-01-01T00:00:00Z
FINAL_DATE = 2025-01-01T04:00:00Z
INTERVAL = PT4H

FILE_INTERVAL = ${INTERVAL}1S
OUTPUT_INTERVAL = PT1H

[namelists]
  [[NAMELIST_atm]]
    .remove += dbg_index_nml, extpar_nml, initicon_nml, output_nml atm_vgrid, output_nml atm_dbg, output_nml atm_mon, output_nml lnd_mon
    [[[aes_cop_nml]]]
      aes_cop_config(1)%cinhomi = 1.0
      aes_cop_config(1)%cinhoml_cfl= 1.0
      aes_cop_config(1)%cinhoml_cfo= 1.0
      aes_cop_config(1)%cinhoml_sf = 1.0
      aes_cop_config(1)%cn1lnd = 50.0
      aes_cop_config(1)%cn1sea = 50.0
      aes_cop_config(1)%cn2lnd = 220.0
      aes_cop_config(1)%cn2sea = 100.0
    [[[aes_cov_nml]]]
      aes_cov_config(1)%cqx = 1.e-6
    [[[aes_phy_nml]]]
      aes_phy_config(1)%dt_mig = PT06S
      aes_phy_config(1)%dt_rad = PT5M
      aes_phy_config(1)%dt_two =
      aes_phy_config(1)%dt_vdf = PT06S
      aes_phy_config(1)%iqneg_d2p = 2
      aes_phy_config(1)%iqneg_p2d = 2
      aes_phy_config(1)%l2moment = false
      aes_phy_config(1)%lamip = false
      aes_phy_config(1)%lice = false
      aes_phy_config(1)%ljsb = false
      aes_phy_config(1)%llake = false
      aes_phy_config(1)%lmlo = false
      aes_phy_config(1)%zmaxcloudy = 22500.
    [[[aes_rad_nml]]]
      aes_rad_config(1)%cecc = 0.0
      aes_rad_config(1)%cobld = 0.0
      aes_rad_config(1)%icosmu0 = 0
      aes_rad_config(1)%irad_aero = 0
      aes_rad_config(1)%irad_cfc11 = 0
      aes_rad_config(1)%irad_cfc12 = 0
      aes_rad_config(1)%irad_ch4 = 2
      aes_rad_config(1)%irad_co2 = 2
      aes_rad_config(1)%irad_h2o = 1
      aes_rad_config(1)%irad_n2o = 2
      aes_rad_config(1)%irad_o2 = 0
      aes_rad_config(1)%irad_o3 = 4
      aes_rad_config(1)%isolrad = 7
      aes_rad_config(1)%l_orbvsop87 = false
      aes_rad_config(1)%l_sph_symm_irr = true
      aes_rad_config(1)%ldiur = false
      aes_rad_config(1)%vmr_ch4 = 1650.e-09
      aes_rad_config(1)%vmr_co2 = 348.e-06
      aes_rad_config(1)%vmr_n2o = 306.e-09
      # Remove from DEFAULT settings
      aes_rad_config(1)%lyr_perp =
      aes_rad_config(1)%yr_perp =
    [[[aes_vdf_nml]]]
      aes_vdf_config(1)%energy_type = 2
      aes_vdf_config(1)%pr0 = 0.7
      aes_vdf_config(1)%solver_type = 2
      aes_vdf_config(1)%turb = 2
      aes_vdf_config(1)%use_louis = true
      aes_vdf_config(1)%use_tmx = true
    [[[dynamics_nml]]]
      lcoriolis = false
    [[[grid_nml]]]
      grid_angular_velocity = 0.
    [[[interpol_nml]]]
      rbf_scale_mode_ll = 1
      rbf_vec_scale_c = 0.45
      rbf_vec_scale_e = 0.45
      rbf_vec_scale_v = 0.45
    [[[io_nml]]]
      inextra_2d = 0
      inextra_3d = 0
      itype_pres_msl = 4
      lnetcdf_flt64_output = true
      restart_file_type = 5
      write_initial_state =
    [[[nh_testcase_nml]]]
      ape_sst_case = sst_const
      ape_sst_val = 26.85
      nh_test_name = RCEMIP_analytical
    [[[nonhydrostatic_nml]]]
      damp_height = 19000.
      divdamp_fac = 0.002
      htop_moist_proc = 22500.
      ndyn_substeps = 5
      rayleigh_coeff = 0.1
      vwind_offctr = 0.2
    [[[output_nml atm_2d]]]
      ml_varlist = ps, psl, tas, clt, prw, clwvi, clivi, ts, qrvi, qsvi, qgvi, hfls, hfss, evspsbl, prlr, prls, cptgzvi, pr_rain, pr_snow, pr_grpl, pr_ice, uas, vas, rsdt, pr, rsut, rsutcs, rlut, rlutcs, rsds, rsdscs, rlds, rldscs, rsus, rsuscs, rlus
      operation = mean
      output_grid = true
    [[[output_nml atm_3d]]]
      ml_varlist = ps, pfull, zg, rho, ta, theta_v, ua, va, wa, hus, clw, cli, qr, qs, qg, cptgz
      operation = mean
      output_grid = true
    [[[output_nml atm_cgrid]]]
      filename_format = <output_filename>_<levtype_l>
      include_last =
      ml_varlist = clon, clat, areacella, zghalf, zg
      output_end = $INITIAL_DATE
      output_grid = true
    [[[parallel_nml]]]
      io_process_stride = 6
      nblocks_c = 0
      nproma = 32
      nproma_sub = 32
      num_io_procs = 2
      pio_type =
    [[[run_nml]]]
      activate_sync_timers = true
      iforcing = 2
      ldynamics = true
      ltestcase = true
      ltransport = true
      modeltimestep = PT06S
      msg_level = 12
      num_lev = 75
      output = nml
      profiling_output = 1
      restart_filename = ${EXP_ID}_restart_atm_<rsttime>.nc
    [[[sleve_nml]]]
      decay_exp =
      decay_scale_1 =
      decay_scale_2 =
      flat_height =
      htop_thcknlimit = 40000.
      max_lay_thckn = 500.
      min_lay_thckn = 75.
      stretch_fac =
      top_height = 33947.
    [[[transport_nml]]]
      ihadv_tracer = 20, 20, 20, 20, 20, 20
      itype_hlimit = 3, 4, 4, 4, 4, 4
      ivadv_tracer = 3, 3, 3, 3, 3, 3
      tracer_names = hus, clw, cli, qr, qs, qg
  [[icon_master.namelist]]
    [[[master_nml]]]
      lrestart = false
    [[[master_time_control_nml]]]
      experimentstartdate = $INITIAL_DATE
[files]
  [[atmosphere]]
    [[[restart_data]]]
      .hide = true
    [[[restart]]]
      .hide = true

    [[[model]]]
      [[[[data]]]]
        .sub_dir = data
        rrtmgp-cloud-optics-coeffs-lw.nc = ECHAM6_CldOptProps_rrtmgp_lw.nc
        rrtmgp-cloud-optics-coeffs-sw.nc = ECHAM6_CldOptProps_rrtmgp_sw.nc
        dmin_wetgrowth_lookup.nc = .
        coefficients_lw.nc = rrtmgp-gas-lw-g128.nc
        coefficients_sw.nc = rrtmgp-gas-sw-g112.nc
    [[[mapped]]]
      .base_dir = /pool/data/ICON/grids/public/mpim/Torus_Triangles_100000m_x_100000m_res1000m
      .sub_dir =
      icon_grid_G.nc = Torus_Triangles_100000m_x_100000m_res1000m.nc
      [[[[ozone]]]]
        .base_dir = /pool/data/ICON/grids/public/mpim/Torus_Triangles_100000m_x_100000m_res1000m
        .sub_dir =
        bc_ozone.nc = rcemip_analytical_o3_100000m_x_100000m_res1000m.nc
[jobs]
  .remove += clean, intake, mon, mon_index, post, run, mon_log
  [[run_start]]
    .trigger =
  [[run]]
    time_limit = 00:05:00
    nodes = 1
