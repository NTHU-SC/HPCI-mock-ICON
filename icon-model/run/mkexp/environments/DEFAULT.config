VERSION_ = $$Id: run/mkexp/environments/DEFAULT.config 6 2025-06-10 06:54:49Z m221078 $$

[jobs]

  ldd = ldd
  progress_command = echo progress indicator:

  # Environment variables for job information
  name_environ = 0
  id_environ = $$

  log_file = $EXP_ID.run.$$(printf %08d $$$id_environ).log

  default_threads_per_task = 1
  default_cpus_per_node = 4
  hardware_threads = true

[MPI]

  command = eval("$MPI_LAUNCH" if "$MPI_LAUNCH" else "mpiexec")
