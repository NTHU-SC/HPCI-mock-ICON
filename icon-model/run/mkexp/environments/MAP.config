# Mapping of build info to mkexp environment
#

[levante_gpu]
  host_fqdn = l*.lvt.dkrz.de
  gpu_enabled = true
[levante]
  host_fqdn = l*.lvt.dkrz.de
[mpimet]
  host_fqdn = *.mpimet.mpg.de
  host_os = linux-gnu
[macOS]
  host_os = darwin*
