#
# Insert test suite settings
#

VERSION_ = $$Id: run/mkexp/options/test/suite.config 1 2025-07-21 11:26:52Z m221078 $$

[jobs]

  .type = serial

  threads_per_task = $default_threads_per_task
  cpus_per_node = $default_cpus_per_node
  cpus_per_thread = eval(1 if is_set('$hardware_threads') else 2)

  [[remove_files]]
    args = $SCRIPT_DIR/$EXP_ID.date

  [[diff_test]]
    .var_format = {%s}

  [[run_tests]]

  [[run_start]]
    .trigger = run_tests

  [[run_restart_start]]
    .extends = run_start
    .trigger = run_restart
    subdir = run_restart_start
    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[master_time_control_nml]]]]]
          checkpointtimeintval = $TEST_RESTART_INTERVAL
          restarttimeintval = $TEST_RESTART_INTERVAL
      [[[[NAMELIST_atm]]]]
        [[[[[output_nml]]]]]
          file_interval = $TEST_RESTART_INTERVAL
      [[[[NAMELIST_oce]]]]
        [[[[[output_nml]]]]]
          file_interval = $TEST_RESTART_INTERVAL
  [[run_restart]]
    .extends = run
    .trigger = remove_files, diff_test -O $subdir -O run_restart_start
    subdir = run_restart
    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[master_time_control_nml]]]]]
          checkpointtimeintval = $TEST_RESTART_INTERVAL
          restarttimeintval = $TEST_RESTART_INTERVAL
      [[[[NAMELIST_atm]]]]
        [[[[[output_nml]]]]]
          file_interval = $TEST_RESTART_INTERVAL
      [[[[NAMELIST_oce]]]]
        [[[[[output_nml]]]]]
          file_interval = $TEST_RESTART_INTERVAL

  [[run_openmp_start]]
    .hide = eval(not is_set('$openmp_enabled'))
    .extends = run_start
    .trigger = diff_test -O $subdir
    subdir = run_openmp
    threads_per_task = 1
    cpus_per_node = eval($default_cpus_per_node//$default_threads_per_task)

  [[run_nproma_start]]
    .extends = run_start
    .trigger = diff_test -O $subdir
    subdir = run_nproma
    [[[namelists]]]
      [[[[NAMELIST_atm]]]]
        [[[[[parallel_nml]]]]]
          nproma = eval($ATMO_BLOCK_SIZE + 1)
      [[[[NAMELIST_oce]]]]
        [[[[[parallel_nml]]]]]
          nproma = eval($OCEAN_BLOCK_SIZE + 1)

  [[run_mpi_start]]
    .hide = eval(not is_set('$mpi_enabled'))
    .extends = run_start
    .trigger = diff_test -O $subdir
    subdir = run_mpi
    cpus_per_node = eval($default_cpus_per_node - $threads_per_task*$cpus_per_thread)
