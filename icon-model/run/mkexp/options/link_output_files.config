#
# Directly link output files to data directory
#
# Fail if work and data directory are not on the same file system
#

VERSION_ = $$Id: run/mkexp/options/link_output_files.config 1 2025-08-29 14:42:07Z m221078 $$

[jobs]
  [[run]]
    .trigger += link -I $${EXPDIR}
  [[link]]
    .var_format = {%s}
    .type = serial
