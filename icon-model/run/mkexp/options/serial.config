#
# Use a single batch job for all job scripts
#

VERSION_ = $$Id: run/mkexp/options/serial.config 1 2025-08-14 11:38:31Z m221078 $$

[jobs]

  [[run]]
    # move 'run' to end of list
    .trigger -= run
    .trigger += run
    batch_command = $ksh

  [[post,mon]]
    .type = serial
