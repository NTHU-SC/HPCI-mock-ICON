#--------------------------------------------------------------------------------------------------
#
# BuildBot test setup of the R2B6 AMIP experiment on GPUs
#   including output and restart write
#
# If this fails, see run/examples/amip-aes_R2B6_gpu.config
# for maual debugging.
#

EXP_TYPE = amip-aes-R2B6
EXP_OPTIONS = suppress_default_output, buildbot
ENVIRONMENT = levante_gpu

WORK_ROOT = $MODEL_ROOT
DATA_ROOT = $MODEL_ROOT

FINAL_DATE = 'add_days($INITIAL_DATE, 1)'
INTERVAL = P1D # Restart interval

[namelists]
  [[NAMELIST_atm]]
    [[[parallel_nml]]]
      nproma = 0
      nblocks_c = 1
      nproma_sub =
      nblocks_sub = 4

[jobs]
  [[run]]
    .trigger = run
     nodes = 1
     num_io_tasks = 2
     time_limit = 00:4:20
     debug_level = 2        # To get loggin from runscript
    [[[batch]]]
      constraint = a100_80
