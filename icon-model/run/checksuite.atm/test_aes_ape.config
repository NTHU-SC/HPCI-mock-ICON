# ------------------------------------------
# Aqua Planet Experiment (APE) - Sapphire Configuration
# author_list="Angel Peinado, MPIM"
# ------------------------------------------
# This file describes an aqua planet experiment based with Sapphire configuration.
# It is based in the APE protocol:
# - constant zonal SST, no land, no sea icem, no aerosol
# - parameterization used Radiation, Turbulence and Micro-physics scheme
# - well mixed greenhouse gases CO2
# - constant O3 concentration
#=============================================================================

EXP_TYPE = AES/ape-R02B04L90
EXP_OPTIONS = suppress_default_output, buildbot

WORK_ROOT = $MODEL_ROOT
DATA_ROOT = $MODEL_ROOT

INITIAL_DATE = 1979-01-01T00:00:00Z
FINAL_DATE = 1979-01-04T00:00:00Z
INTERVAL = P3D

[jobs]
  [[run]]
    .trigger = run
    use_mpmd = false
    use_hostfile = false
    use_cpu_mask = false
    nodes = 1
    time_limit = 00:10:00

[MPI]
  command = "srun -l --kill-on-bad-exit=1 --cpu-bind=quiet,cores --distribution=plane=$${SLURM_JOB_NUM_NODES} --propagate=STACK,CORE"
