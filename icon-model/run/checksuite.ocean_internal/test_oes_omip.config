#
# Test setup for OMIP
#

EXP_TYPE = OES/ocean_omip-R02B04L40

EXP_OPTIONS = buildbot
WORK_ROOT = $MODEL_ROOT
DATA_ROOT = $MODEL_ROOT

[jobs]
  [[run_start]]
    .trigger=
  [[run]]
    nodes = 1
    time_limit = 00:05:00
    use_hostfile = false
    use_mpmd = false
    use_cpumask = false
