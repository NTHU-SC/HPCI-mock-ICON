#--------------------------------------------------------------------------------------------------
#
# Example config for a standard AMIP experiment with a standalone atmosphere
# using AES physics with the JSBACH land surface scheme and TMX turbulence
# (nextGEMS namelist).
# This experiment corresponds to run/exp.aes_amip.run for the R02B08 grid
# with its default output of two files (output_atm_qp=yes).
#

EXP_TYPE = amip-aes-R2B8
EXP_OPTIONS = suppress_default_output
ENVIRONMENT = levante_gpu
ACCOUNT = eval(feedback.die("please set ACCOUNT in your experiment config"))

# For testing we use only short runtime
INITIAL_DATE = 1979-01-01T00:00:00
FINAL_DATE = 1979-01-01T03:00:00
INTERVAL = PT3H # Restart interval

[namelists]
  [[NAMELIST_atm]]
    [[[parallel_nml]]]
      nproma = 0
      nblocks_c = 2
      nproma_sub =
      nblocks_sub = 5

[jobs]
  [[run]]
    .trigger = run
     nodes = 8
     num_io_tasks = 2
     time_limit = 00:10:00
    [[[batch]]]
      constraint = a100_80


# *** Examples of common modifications (include in the sections if required)
# ------------------------------------------------------------------------
# # Generate experiments folders in the BUILD_DIR
# TOP_SRCDIR = $BUILD_DIR
# DATA_ROOT = $MODEL_ROOT
#
# ------------------------------------------------------------------------
# # Disable all output file writing
# [namelists]
#   [[NAMELIST_atm]]
#     [[[output_nml atm_2d_P1D_ml]]]
#       .hide = true
#     [[[output_nml atm_3d_qp_ml]]]
#       .hide = true
#
# [jobs]
#   [[run]]
#      num_io_tasks = 0
#
# ------------------------------------------------------------------------
# # Disable all output and restart file writing
# [namelists]
#   [[NAMELIST_atm]]
#     [[[run_nml]]]
#       output = none
#
# [jobs]
#   [[run]]
#      num_io_tasks = 0
#
# ------------------------------------------------------------------------
# # Note: When you change the number of GPU nodes you should also
# #       change nblocks_c and nblocks_sub to get the best performance.
# #       Some values are:
# #        * nodes = 16: nblocks_c = 1 & nblocks_sub = 4
# #        * nodes >=32: nblocks_c = 1 & nblocks_sub = 1
