# [namelists]
#   [[NAMELIST_atm]]
#     [[[output_nml atm_2d_P1D_ml]]]
#       .hide = true
#     [[[output_nml atm_3d_qp_ml]]]
#       .hide = true
#
# [jobs]
#   [[run]]
#      num_io_tasks = 0
#
# ------------------------------------------------------------------------
# # Disable all output and restart file writing
# [namelists]
#   [[NAMELIST_atm]]
#     [[[run_nml]]]
#       output = none
#
# [jobs]
#   [[run]]
#      num_io_tasks = 0
#
# ------------------------------------------------------------------------
