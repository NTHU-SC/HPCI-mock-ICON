#--------------------------------------------------------------------------------------------------
#
# Example config for a standard AMIP experiment with a standalone atmosphere
# using AES physics with the JSBACH land surface scheme and TMX turbulence
# (nextGEMS namelist).
# This experiment corresponds to run/exp.aes_amip with its default output
# of two files (output_atm_qp=yes).
#

EXP_ID = amip-aes-R2B4
EXP_TYPE = amip-aes-R2B4
EXP_OPTIONS = suppress_default_output
ACCOUNT = eval(feedback.die("please set ACCOUNT in your experiment config"))

[jobs]
  [[run]]
    .trigger = run
    use_mpmd = false
    use_hostfile = false
    use_cpu_mask = false
    nodes = 1
    threads_per_task = 4
    time_limit = 00:10:00

[MPI]
  command = "srun -l --kill-on-bad-exit=1 --cpu-bind=quiet,cores --distribution=plane=$${SLURM_JOB_NUM_NODES} --propagate=STACK,CORE"


# *** Examples of common modifications (include in the sections if required)
# ------------------------------------------------------------------------
# # Generate experiments folders in the BUILD_DIR
# TOP_SRCDIR = $BUILD_DIR
# DATA_ROOT = $MODEL_ROOT
#
# ------------------------------------------------------------------------
# # Change simulated time
# INITIAL_DATE = 1979-01-01T00:00:00
# FINAL_DATE = 1979-01-01T03:00:00
# INTERVAL = PT3H
#
# ------------------------------------------------------------------------
# # Change the resolution
# EXP_TYPE = amip-aes-R2B4
# EXP_TYPE = amip-aes-R2B6  # with nodes >= 4
# EXP_TYPE = amip-aes-R2B8  # with nodes >= 32
# EXP_TYPE = amip-aes-R2B9  # with nodes ~500
# EXP_TYPE = amip-aes-R2B10 # with nodes ~600
