#--------------------------------------------------------------------------------------------------
#
# Example config for a standard AMIP experiment with a standalone atmosphere
# using AES physics with the JSBACH land surface scheme and TMX turbulence
# (nextGEMS namelist).
# This experiment corresponds to run/exp.aes_amip with its default output of
# two files (output_atm_qp=yes).
#

EXP_ID = amip-aes-R2B4_gpu
EXP_TYPE = amip-aes-R2B4
EXP_OPTIONS = suppress_default_output
ENVIRONMENT = levante_gpu
ACCOUNT = eval(feedback.die("please set ACCOUNT in your experiment config"))

[namelists]
  [[NAMELIST_atm]]
    [[[parallel_nml]]]
      nproma = 0
      nblocks_c = 1
      nproma_sub =
      nblocks_sub = 4

[jobs]
  [[run]]
    .trigger = run
     nodes = 1
     num_io_tasks = 2
     time_limit = 00:05:00
    [[[batch]]]
      constraint = a100_80


# *** Examples of common modifications (include in the sections if required)
# ------------------------------------------------------------------------
# # Generate experiments folders in the BUILD_DIR
# TOP_SRCDIR = $BUILD_DIR
# DATA_ROOT = $MODEL_ROOT
#
# ------------------------------------------------------------------------
# # Change simulated time
# INITIAL_DATE = 1979-01-01T00:00:00
# FINAL_DATE = 1979-01-01T03:00:00
# INTERVAL = PT3H
#
# ------------------------------------------------------------------------
# # Change the resolution
# EXP_TYPE = amip-aes-R2B4
# EXP_TYPE = amip-aes-R2B6
# EXP_TYPE = amip-aes-R2B8
# EXP_TYPE = amip-aes-R2B9
# # Please be aware that an R2B10 grid dos not fit to Levantes GPU partition.
# # Note: When you change the resolution you need to change the number of
# #       GPU nodes and you should also change nblocks_c and nblocks_sub
# #       to get the best performance.
# #       Some values are:
# #        * amip-aes-R2B4:  nodes =  1, nblocks_c = 1 & nblocks_sub = 4
# #        * amip-aes-R2B6:  nodes =  1, nblocks_c = 1 & nblocks_sub = 4
# #        * amip-aes-R2B8:  nodes =  8, nblocks_c = 2 & nblocks_sub = 5
# #                          nodes = 16, nblocks_c = 1 & nblocks_sub = 4
# #                          nodes >=32, nblocks_c = 1 & nblocks_sub = 1
# #        * amip-aes-R2B9:  nodes = 24, nblocks_c = 1 & nproma_sub = 800
