#--------------------------------------------------------------------------------------------------
#
# Example config for a standard AMIP experiment with a standalone atmosphere
# using AES physics with the JSBACH land surface scheme and TMX turbulence
# (nextGEMS namelist).
# This experiment corresponds to run/exp.aes_amip.run for the R02B06 grid
# with its default output of two files (output_atm_qp=yes).
#

EXP_TYPE = amip-aes-R2B6
EXP_OPTIONS = suppress_default_output
ACCOUNT = eval(feedback.die("please set ACCOUNT in your experiment config"))

# For testing we use only short runtime
FINAL_DATE = 'add_days($INITIAL_DATE, 1)'
INTERVAL = P1D # Restart interval

[jobs]
  [[run]]
    .trigger = run # disable post-processing
    use_mpmd = false
    use_hostfile = false
    use_cpu_mask = false
    nodes = 16
    threads_per_task = 4
    time_limit = 00:10:00

[MPI]
  command = "srun -l --kill-on-bad-exit=1 --cpu-bind=quiet,cores --distribution=plane=$${SLURM_JOB_NUM_NODES} --propagate=STACK,CORE"


# *** Examples of common modifications (include in the sections if required)
