#
# Test setup for global coupled atmosphere/ocean model
#
# Defaults are set for use in buildbot
#

EXP_TYPE = AES/coupled-R02B04L90
EXP_OPTIONS = output/coupled_test, buildbot, test/suite

WORK_ROOT = $MODEL_ROOT
DATA_ROOT = $MODEL_ROOT

INITIAL_DATE = 2014-01-20
FINAL_DATE = 2014-01-20T06:00:00
INTERVAL = PT6H
FILE_INTERVAL = $INTERVAL

TEST_RESTART_INTERVAL = PT3H

[jobs]
  [[run]]
    use_cpu_mask = false
    use_hostfile = false
    use_mpmd = false
    time_limit = 10
