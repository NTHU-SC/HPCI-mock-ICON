set -e
verbose=:
REPOTOP=$(git rev-parse --show-toplevel)
relhooksrc='../../scripts/git-hooks'
if [[ -d "${REPOTOP}/.git/hooks" ]]; then
  # currently, only the pre-commit hook is needed
  # shellcheck disable=SC2043
  for hook in pre-commit ; do
    hook_inst="${REPOTOP}/.git/hooks/$hook"
    if [[ -e "${hook_inst}" ]]; then
      if link_target=$(readlink "${hook_inst}") \
          && [[ $link_target = "${relhooksrc}/$hook" ]]; then
        if ${verbose-false} ; then
           printf "%s\n" "skipping already installed hook $hook" >&2
        fi
        continue
      fi
      printf "%s\n" "warning: git hook $hook already installed!" \
             "\tcreating backup and replacing.">&2
      hook_bak=$(mktemp "${hook_inst}.bak${EPOCHSECONDS}.XXXXXXXX")
      mv "${hook_inst}" "${hook_bak}"
    fi
    ln -s "${relhooksrc}/${hook}" "${hook_inst}"
  done
else
  printf "%s\n" "error: Cannot find hook directory!" >&2
  exit 1
fi
