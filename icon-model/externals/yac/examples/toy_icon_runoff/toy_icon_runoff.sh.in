@ENABLE_MCI_FALSE@exit 77
@ENABLE_UTILS_FALSE@exit 77
@HAVE_NETCDF_FALSE@exit 77
@TEST_MPI_FALSE@exit 77

CONFIG_FILE=@top_srcdir@/input/toy_icon_runoff.yaml
GRID_DIR=@top_builddir@/grids

@TEST_MPI_TRUE@@MPI_LAUNCH@ \
  -n 1 ./toy_icon_runoff_atm.x -c $CONFIG_FILE -g $GRID_DIR/icon_grid_0043_R02B04_G.nc : \
  -n 2 ./toy_icon_runoff_ocn.x -c $CONFIG_FILE -g $GRID_DIR/icon_grid_0036_R02B04_O.nc
