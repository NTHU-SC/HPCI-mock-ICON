set -eu
unset CDPATH
ulimit -c 0

MODULES="Stages/2025 NVHPC/25.5-CUDA-12 ParaStationMPI/5.10.0-1 netCDF-Fortran/4.6.1 ecCodes/2.39.0  libfyaml/.0.9 CMake make"
BUILD_ENV="module --force purge; module load ${MODULES}; module list};"

script_dir=$(cd "$(dirname "$0")"; pwd)
icon_dir=$(cd "${script_dir}/../.."; pwd)

NVHPC_ROOT="/p/software/default/stages/2025/software/NVHPC/25.5-CUDA-12"
GCC_ROOT="/p/software/jupiter/stages/2025/software/GCCcore/13.3.0"

STDCPP_ROOT=${GCC_ROOT}
STDCPP_LIBS='-lstdc++'

MPI_ROOT="/p/software/default/stages/2025/software/psmpi/5.10.0-1-NVHPC-24.9-CUDA-12"
MPI_extra_ldflags='-L/p/software/jupiter/stages/2024/software/pscom/5-default-GCCcore-12.3.0/lib -L/p/software/jupiter/stages/2025/software/CUDA/12/lib'
MPI_extra_libs='-lpscom -lcudart'

HDF5_ROOT="/p/software/default/stages/2025/software/HDF5/1.14.5-npsmpic-2024a"
HDF5_LIBS='-lhdf5_hl -lhdf5'

NETCDF_ROOT="/p/software/default/stages/2025/software/netCDF/4.9.2-npsmpic-2024a"
NETCDF_extra_ldflags="-L/p/software/default/stages/2025/software/PnetCDF/1.13.0-npsmpic-2024a/lib -L/p/software/jupiter/stages/2025/software/bzip2/1.0.8-GCCcore-13.3.0/lib -L/p/software/default/stages/2025/software/Blosc/1.21.6-GCCcore-13.3.0/lib -L/p/software/default/stages/2025/software/libaec/1.1.3-GCCcore-13.3.0/lib"
NETCDF_LIBS='-lnetcdf -lblosc -lsz -lbz2 -lpnetcdf'

NETCDFF_ROOT="/p/software/default/stages/2025/software/netCDF-Fortran/4.6.1-npsmpic-2024a"
NETCDFF_LIBS='-lnetcdff'

BLAS_LAPACK_LIBS='-llapack -lblas'

ECCODES_ROOT="/p/software/default/stages/2025/software/ecCodes/2.39.0-npsmpic-2024a"
ECCODES_extra_ldflags="$(PKG_CONFIG_PATH=${ECCODES_ROOT}/lib64/pkgconfig:${PKG_CONFIG_PATH-} pkg-config --libs-only-L --libs-only-other --static eccodes)"
ECCODES_LIBS="$(PKG_CONFIG_PATH=${ECCODES_ROOT}/lib64/pkgconfig:${PKG_CONFIG_PATH-} pkg-config --libs-only-l --static eccodes)"

FYAML_ROOT="/p/software/default/stages/2025/software/libfyaml/0.9-GCCcore-13.3.0"
FYAML_LIBS='-lfyaml'

XML2_ROOT='/p/software/jupiter/stages/2025/software/libxml2/2.12.7-GCCcore-13.3.0'
XML2_LIBS='-lxml2'

################################################################################

CC="${MPI_ROOT}/bin/mpicc"
CFLAGS='-g -O2'

# Let YAC find LAPACK with the C compiler:
ICON_YAC_CFLAGS='-fortranlibs'

CPPFLAGS="-I${HDF5_ROOT}/include -I${NETCDF_ROOT}/include -I${ECCODES_ROOT}/include -I${FYAML_ROOT}/include -I${XML2_ROOT}/include/libxml2"

CXX="${NVHPC_ROOT}/compilers/bin/nvc++"
CXXFLAGS='-g -O2'

FC="${MPI_ROOT}/bin/mpifort"
FCFLAGS="-I${NETCDFF_ROOT}/include -g -O1 -Mrecursive -Mallocatable=03 -Mstack_arrays -Minfo=inline"

LDFLAGS="-L${STDCPP_ROOT}/lib64 ${MPI_extra_ldflags} ${NETCDF_extra_ldflags} -L${HDF5_ROOT}/lib -L${NETCDF_ROOT}/lib64 -L${NETCDFF_ROOT}/lib ${ECCODES_extra_ldflags}  -L${ECCODES_ROOT}/lib64 -L${FYAML_ROOT}/lib"
LIBS="${STDCPP_LIBS} ${MPI_extra_libs} ${XML2_LIBS} ${FYAML_LIBS} ${ECCODES_LIBS} ${BLAS_LAPACK_LIBS} ${NETCDFF_LIBS} ${NETCDF_LIBS} ${HDF5_LIBS} "

MPI_LAUNCH=false

EXTRA_CONFIG_ARGS="--disable-mpi-checks --disable-parallel-netcdf"

################################################################################

"${icon_dir}/configure" \
BUILD_ENV="${BUILD_ENV}" \
CC="${CC}" \
CFLAGS="${CFLAGS}" \
CPPFLAGS="${CPPFLAGS}" \
CXX="${CXX}" \
CXXFLAGS="${CXXFLAGS}" \
FC="${FC}" \
FCFLAGS="${FCFLAGS}" \
ICON_YAC_CFLAGS="${ICON_YAC_CFLAGS}" \
LDFLAGS="${LDFLAGS}" \
LIBS="${LIBS}" \
MPI_LAUNCH="${MPI_LAUNCH}" \
${EXTRA_CONFIG_ARGS} \
"$@"

for arg in "$@"; do
  case $arg in
    -help | --help | --hel | --he | -h | -help=r* | --help=r* | --hel=r* | --he=r* | -hr* | -help=s* | --help=s* | --hel=s* | --he=s* | -hs*)
      test -n "${EXTRA_CONFIG_ARGS}" && echo '' && echo "This wrapper script ('$0') calls the configure script with the following extra arguments, which might override the default values listed above: ${EXTRA_CONFIG_ARGS}"
      exit 0 ;;
  esac
done

# Copy runscript-related files when building out-of-source:
if test $(pwd) != $(cd "${icon_dir}"; pwd); then
  echo "Copying runscript input files from the source directory..."
  rsync -uavz ${icon_dir}/run . --exclude='*.in' --exclude='.*' --exclude='standard_*' --exclude=mkexp
  ln -sf -t run/ ${icon_dir}/run/{standard_*,mkexp}
  for dir in \
    'externals/art/runctrl_examples' \
    'externals/ecrad/data' \
    'externals/jsbach/data'
  do
    src="${icon_dir}/${dir}"
    test -d "${src}" && mkdir -p "${dir}" && rsync -uavz "${src}/" "${dir}"
  done
  rsync -uavz ${icon_dir}/make_runscripts .
  rsync -uavz ${icon_dir}/scripts .
  ln -sf ${icon_dir}/data
  ln -sf ${icon_dir}/vertical_coord_tables
fi
