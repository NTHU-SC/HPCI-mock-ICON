#! /bin/bash
#
# ape_from_spinup_short.run
#
# Generated by Make Experiments! (mkexp) 1.4.3
#
# $Id: run/mkexp/defaults/DEFAULT.run.tmpl 25 2025-08-01 12:15:22Z k202204 $
#
# $Id: run/mkexp/defaults/DEFAULT.config 20 2025-05-23 08:22:31Z m221078 $
# icon 2025.10-2
# $Id: run/mkexp/types/aes_ape.config 8 2025-07-08 m300901 $
# $Id:standard_options/suppress_default_output.config 1 2025-02-07 m221078 $
# $Id: run/mkexp/environments/DEFAULT.config 6 2025-06-10 06:54:49Z m221078 $
# $Id: run/mkexp/environments/levante.config 8 2025-06-10 06:54:49Z m221078 $
#
#=============================================================================

#
# Setup for levante (SLURM)
#
# $Id: levante.tmpl 2 2025-02-11 k202123 $
#
#SBATCH --account=ka1125
#SBATCH --job-name=ape_from_spinup_short.run
#SBATCH --partition=compute
#SBATCH --nodes=1
#SBATCH --threads-per-core=2
# the following is needed to work around a bug that otherwise leads to
# a too low number of ranks when using compute,compute2 as queue
#SBATCH --mem=0
#SBATCH --output=/work/ka1125/m301160/icon-model/experiments/ape_from_spinup_short/log/ape_from_spinup_short.run.%8j.log
#SBATCH --exclusive
#SBATCH --time=05:30:00

# Environment variables for the target system

# OpenMP
export OMP_DYNAMIC=false
export OMP_SCHEDULE=guided
export OMP_STACKSIZE=500M
# Intel OpenMP
export KMP_AFFINITY=granularity=fine,scatter
export KMP_LIBRARY=turnaround
# OpenMPI
export OMPI_MCA_btl=self
export OMPI_MCA_coll=^hcoll,ml
export OMPI_MCA_coll_tuned_alltoallv_algorithm=2
export OMPI_MCA_coll_tuned_use_dynamic_rules=true
export OMPI_MCA_io=romio321
export OMPI_MCA_osc=ucx
export OMPI_MCA_pml=ucx
export OMPI_MCA_pml_ucx_opal_mem_hooks=1
# Unified Communication X
export UCX_HANDLE_ERRORS=bt
export UCX_IB_ADDR_TYPE=ib_global
export UCX_NET_DEVICES=mlx5_0:1
export UCX_TLS=mm,cma,dc_mlx5,dc_x,self
export UCX_UNIFIED_MODE=y
export UCX_LOG_LEVEL=ERROR # TODO: unsilence UCX warnings
# HDF5 Library
export HDF5_USE_FILE_LOCKING=FALSE
# GNU C Library
export MALLOC_TRIM_THRESHOLD_=-1
# Intel MKL
export MKL_DEBUG_CPU_TYPE=5
export MKL_ENABLE_INSTRUCTIONS=AVX2
#=============================================================================
set -euo pipefail
# Utilities
UTILS_DIR=/work/ka1125/m301160/icon-model/utils
PATH=$UTILS_DIR:$PATH

# Support log style output
if ! ${TIMEWARP_IS_RUNNING_:-false}
then
    pipe=ape_from_spinup_short_run_$$.pipe
    mkfifo $pipe
    trap "cd $PWD && rm -f $pipe" EXIT
    /usr/bin/python3 $UTILS_DIR/timewarp $pipe &
    exec > $pipe 2>&1
    export TIMEWARP_IS_RUNNING_=true
fi

MODEL_DIR=/work/ka1125/m301160/icon-model
PREFIX=/work/ka1125/m301160/icon-model
SCRIPT_DIR=/work/ka1125/m301160/icon-model/experiments/ape_from_spinup_short/scripts


# Convenience link to log file
ln -snvf /work/ka1125/m301160/icon-model/experiments/ape_from_spinup_short/log/ape_from_spinup_short.run.$(printf %08d $SLURM_JOBID).log $SCRIPT_DIR/ape_from_spinup_short.run.log

# how to submit the next job
# --------------------------
job_name="ape_from_spinup_short.run"

# Load traditional error handling
. $PREFIX/run/add_run_routines
# Reset files and file names for check_error and check_final_status
final_status_file=${SCRIPT_DIR}/${job_name}.final_status
current_status_file=${SCRIPT_DIR}/${job_name}.status
rm -f ${final_status_file} ${current_status_file}

#=============================================================================
#
# OpenMP environment variables
# ----------------------------
export OMP_NUM_THREADS=1
export ICON_THREADS=$OMP_NUM_THREADS
#
# MPI variables
# -------------
no_of_nodes=${SLURM_JOB_NUM_NODES:=1}

cpus_per_task=2
slurm_cpus_per_node=${SLURM_JOB_CPUS_PER_NODE%%\(*}
cpus_per_node=${slurm_cpus_per_node:-256}
mpi_procs_pernode=$((cpus_per_node/cpus_per_task))
hiopy_tasks=0
mpi_total_procs=$((no_of_nodes * mpi_procs_pernode))
#
#=============================================================================

# load local setting, if existing
# -------------------------------
if [ -a ../setting ]
then
  echo "Load Setting"
  . ../setting
fi

# environment variables for the experiment
# ----------------------------------------
export EXPNAME=ape_from_spinup_short

# how to start the icon model
# ---------------------------





export START="srun -l --kill-on-bad-exit=1 --cpu-bind=quiet,cores --distribution=plane=${SLURM_JOB_NUM_NODES} --propagate=STACK,CORE --cpus-per-task=$cpus_per_task -n $mpi_total_procs"
export MODEL="/work/ka1125/m301160/icon-model/bin/icon"

# cdo for post-processing
# -----------------------
cdo="cdo"
cdo_diff="cdo diffn"

#=============================================================================

ulimit -s 4194304
ulimit -c 0

# ----------------------------------------------------------------------------
# ICON
#
# ------------------------------------------
# Copyright (C) 2004-2026, DWD, MPI-M, DKRZ, KIT, ETH, MeteoSwiss
# Contact information: icon-model.org
# See AUTHORS.TXT for a list of authors
# See LICENSES/ for license information
# SPDX-License-Identifier: BSD-3-Clause
# ------------------------------------------
# Aqua Planet Experiment (APE) - Sapphire Configuration
# author_list="Angel Peinado, MPIM"
# ------------------------------------------
# This file describes an aqua planet experiment based with Sapphire configuration.
# It is based in the APE protocol:
# - constant zonal SST, no land, no sea icem, no aerosol
# - parameterization used Radiation, Turbulence and Micro-physics scheme
# - well mixed greenhouse gases CO2
# - constant O3 concentration
# =============================================================================
# ----------------------------------------------------------------------------

# (0) Basic model configuration
# -----------------------------

mpi_oce_nodes=0
mpi_atm_nodes=$((no_of_nodes - mpi_oce_nodes))
mpi_oce_procs=$((mpi_oce_nodes * mpi_procs_pernode))
mpi_atm_procs=$((mpi_total_procs - mpi_oce_procs))
atm_per_node=$(((mpi_atm_procs + mpi_atm_nodes - 1)/mpi_atm_nodes))
#
#--------------------------------------------------------------------------------------------------

# (4) Set variables to configure the experiment:
# ----------------------------------------------


# start and end date+time of experiment
# -------------------------------------
initial_date="1979-01-01"
final_date="1979-07-03T12:00:00.000"

# Read and compute time control information

start_date_file=$SCRIPT_DIR/$EXPNAME.date
exp_log_file=$SCRIPT_DIR/$EXPNAME.log

read start_date < $start_date_file

code=$(/usr/bin/python3 -c "

# Initialize date/time computation


lib_dirs = ['/work/ka1125/m301160/icon-model/externals/mtime/build/python']
import sysconfig
lib_dirs.append(sysconfig.get_path('platlib', vars={'platbase':'/work/ka1125/m301160/icon-model'}))
import sys
sys.path = lib_dirs + sys.path
import mtime

mtime.setCalendar(mtime.CALENDAR_TYPE.proleptic_gregorian)

# Set up diagnostic output

import logging
import os

prefix = '' if os.environ.get('TIMEWARP_IS_RUNNING_') else '%(asctime)s: '
logging.basicConfig(format=prefix+'%(levelname)s%(message)s',
                    level=logging.INFO)
logging.addLevelName(logging.DEBUG, 'Debug: ')
logging.addLevelName(logging.INFO, '')
logging.addLevelName(logging.WARNING, 'Hey: ')
logging.addLevelName(logging.ERROR, 'Oops: ')
logging.addLevelName(logging.CRITICAL, 'Sorry: ')
atmo_time_step = 'PT4M'
ocean_time_step = ''

class namespace: pass

sh = namespace()

sh.initial_date = mtime.DateTime('$initial_date')
sh.final_date = mtime.DateTime('$final_date')
sh.start_date = mtime.DateTime('$start_date')
sh.reference_date = sh.initial_date + mtime.TimeDelta('-P2DT12H')
sh.next_date = sh.start_date + mtime.TimeDelta('P2DT12H')
if sh.next_date > sh.final_date:
    logging.warning('next date after final date; setting next date to final date')
    sh.next_date_orig = sh.next_date
    sh.next_date = sh.final_date
sh.end_date = sh.next_date + mtime.TimeDelta('-' +
    (atmo_time_step or ocean_time_step or 'PT0.001S'))
sh.atmo_reference_jstep = (
    (sh.initial_date, sh.reference_date)//mtime.TimeDelta(atmo_time_step)
    if atmo_time_step else None
)
sh.ocean_reference_jstep = (
    (sh.initial_date, sh.reference_date)//mtime.TimeDelta(ocean_time_step)
    if ocean_time_step else None
)
disturbance_commands = []
if sh.start_date in [mtime.DateTime(date) for date in []]:
    disturbance_commands.append('patch_namelist nonhydrostatic_nml rayleigh_coeff 0.9999 NAMELIST_atm')
sh.disturbance_command = '; '.join(disturbance_commands)

for k, v in vars(sh).items():
    print(f'{k}=\'{v}\'')
")
eval "$code"

# Dates used as timestamps
start_stamp=${start_date%.*}
start_stamp=${start_stamp//[-:]/}
end_stamp=${end_date%.*}
end_stamp=${end_stamp//[-:]/}
next_stamp=${next_date%.*}
next_stamp=${next_stamp//[-:]/}
y0=${start_date%%-*}
yN=${end_date%%-*}

# Mark current run as started in log
echo $(date -u +'%Y-%m-%dT%H:%M:%SZ') ${start_date%:*} ${end_date%:*} ${SLURM_JOBID} start >> $exp_log_file

# Show current start date in job configuration
sh -c 'scontrol update JobId=$SLURM_JOB_ID Comment="$*"' scomment $start_date

#------------------------------------------------------------------------------

# (5) Define the model configuration
#-----------------------------------

# Write namelist files directly to working directory, create this if missing

EXPDIR=/work/ka1125/m301160/icon-model/experiments/ape_from_spinup_short/work/run_${start_stamp}-${end_stamp}

if [[ -d $EXPDIR ]]
then
    echo "$(date +'%Y-%m-%dT%H:%M:%S'): removing run dir '$EXPDIR'"
    rm -fvr $EXPDIR
fi

mkdir -vp $EXPDIR
cd $EXPDIR

#------------------------------------------------------------------------------
# I. coupling section
#------------------------------------------------------------------------------

# I.1 Split the number of total procs and assign to each component
# ----------------------------------------------------------------
oce_min_rank=$((mpi_total_procs - mpi_oce_procs - hiopy_tasks))
oce_max_rank=$((oce_min_rank + mpi_oce_procs - 1))
atm_max_rank=$((oce_min_rank - 1))
oce_group_size=1
oce_inc_rank=1
atm_min_rank=0
atm_group_size=1
atm_inc_rank=1

#
# create ICON master, coupling and model namelists
# ------------------------------------------------
# For a complete list see Namelist_overview and Namelist_overview.pdf
#

cat > icon_master.namelist << EOF
&master_nml
    lrestart = .true.
    read_restart_namelists = .false.
/
&master_time_control_nml
    calendar = 'proleptic gregorian'
    checkpointtimeintval = 'P2DT12H'
    restarttimeintval = 'P2DT12H'
    experimentstartdate = '1979-01-01' ! TODO: hack to reproduce result
    experimentstopdate = '1979-07-03T12:00:00.000'
/
&master_model_nml ! 'atmo'
    model_name = 'atm'
    model_namelist_filename = 'NAMELIST_atm'
    model_type = 1
    model_min_rank = $atm_min_rank
    model_max_rank = $atm_max_rank
    model_inc_rank = $atm_inc_rank
    model_rank_group_size = $atm_group_size
/

EOF

#-----------------------------------------------------------------------------
# II. ATMOSPHERE and LAND
#-----------------------------------------------------------------------------
#
# atmosphere namelist
# -------------------
cat > NAMELIST_atm << EOF
&parallel_nml
    iorder_sendrecv = 3
    nproma = 32
    num_io_procs = 2
    num_restart_procs = 1
    nblocks_c = 0
    nproma_sub = 32
    io_proc_chunk_size = 46
    io_process_stride = 8
/
&grid_nml
    dynamics_grid_filename = 'icon_grid_G.nc'
/
&dynamics_nml
    lmoist_thdyn = .true.
/
&run_nml
    num_lev = 90 ! number of full levels
    modeltimestep = 'PT4M'
    ltestcase = .true. ! run testcase
    ldynamics = .true. ! dynamics
    ltransport = .true. ! transport
    iforcing = 2 ! 0: none, 1: HS, 2: ECHAM, 3: NWP
    output = 'nml'
    msg_level = 15 ! level of details report during integration
    restart_filename = 'ape_from_spinup_restart_atm_<rsttime>.nc'
    activate_sync_timers = .true.
    profiling_output = 1
    timers_level = 10
/
&nonhydrostatic_nml
    ndyn_substeps = 5 ! dtime/dt_dyn
    damp_height = 44000. ! [m]
    rayleigh_coeff = 1.0 ! set to 0.1001 for rerun with little change
    vwind_offctr = 0.2
    divdamp_fac = 0.004
    divdamp_order = 24
    divdamp_trans_end = 17500
    divdamp_trans_start = 12500
    divdamp_type = 32
    exner_expol = 0.333
    hbot_qvsubstep = 16000.
    htop_moist_proc = 22500.
    iadv_rhotheta = 2
    igradp_method = 3
    itime_scheme = 4
    ivctype = 2
    l_zdiffu_t = .true.
    thhgtd_zdiffu = 125.
    thslp_zdiffu = 0.02
/
&interpol_nml
    rbf_scale_mode_ll = 1
/
&sleve_nml
    min_lay_thckn = 25. ! [m]
    top_height = 75000. ! [m]
    stretch_fac = 0.9
    decay_scale_1 = 4000. ! [m]
    decay_scale_2 = 2500. ! [m]
    decay_exp = 1.2
    flat_height = 22500. ! [m]
    htop_thcknlimit = 14000.
    max_lay_thckn = 400.
/
&aes_phy_nml
    ! domain 1
    aes_phy_config(1)%dt_rad = 'PT20M'
    aes_phy_config(1)%dt_vdf = 'PT4M'
    aes_phy_config(1)%dt_mig = 'PT4M'
    aes_phy_config(1)%l2moment = .false.
    aes_phy_config(1)%ljsb = .false.
    aes_phy_config(1)%lice = .false.
    aes_phy_config(1)%llake = .false.
    aes_phy_config(1)%lamip = .false.
    aes_phy_config(1)%lmlo = .false.
/
&aes_rad_nml
    ! domain 1
    aes_rad_config(1)%isolrad = 2
    aes_rad_config(1)%irad_h2o = 1
    aes_rad_config(1)%irad_co2 = 2
    aes_rad_config(1)%irad_ch4 = 0
    aes_rad_config(1)%irad_n2o = 0
    aes_rad_config(1)%irad_o3 = 4 ! constant annual cycle climatology
    aes_rad_config(1)%irad_o2 = 0
    aes_rad_config(1)%irad_cfc11 = 0
    aes_rad_config(1)%irad_cfc12 = 0
    aes_rad_config(1)%irad_aero = 0
    aes_rad_config(1)%vmr_co2 = 284.317e-6 ! constant ratio (348.0e-6)
    aes_rad_config(1)%vmr_ch4 = 808.249e-9 ! constant ratio (1650.0e-9)
    aes_rad_config(1)%vmr_n2o = 273.021e-9 ! constant ratio (306.0e-9)
    aes_rad_config(1)%lyr_perp = .true.
    aes_rad_config(1)%yr_perp = 1850
    aes_rad_config(1)%cecc = 0.0
    aes_rad_config(1)%cobld = 0.0
    aes_rad_config(1)%l_orbvsop87 = .false.
/
! Parameters for all output files
! -------------------------------
&io_nml
    output_nml_dict = 'dict.txt'
    netcdf_dict = 'dict.txt'
    itype_pres_msl = 4
    restart_file_type = 5
    ! restart_write_mode = 'joint procs multifile' ! not useful in r2b4 setup
    ! lnetcdf_flt64_output = .true. ! 64 bit output in all files
    ! lkeep_in_sync = .true. ! sync after each timestep
    write_initial_state = .false.
    lnetcdf_flt64_output = .false.
    restart_write_mode = 'joint procs multifile'
    write_last_restart = .true.
/
&aes_cov_nml
    aes_cov_config(1)%cqx = 1.e-6
/
&aes_vdf_nml
    aes_vdf_config(1)%pr0 = 0.7
    aes_vdf_config(1)%turb = 2
/
&nh_testcase_nml
    ape_sst_case = 'sst_qobs'
    nh_test_name = 'APE_aes'
    zp_ape = 101325
    ztmc_ape = 25.006
/
&transport_nml
    ihadv_tracer = 20, 20, 20, 20, 20, 20
    itype_hlimit = 3, 4, 4, 4, 4, 4
    ivadv_tracer = 3, 3, 3, 3, 3, 3
    tracer_names = 'hus', 'clw', 'cli', 'qr', 'qs', 'qg'
/
&output_nml ! 'atm_2d_p1d_ml'
    output_filename = 'ape_from_spinup_short_atm_2d_P1D'
    filename_format = '<output_filename>_<datetime2>'
    filetype = 5
    mode = 1
    output_start = '1979-01-01'
    output_end = '1979-07-03T12:00:00.000'
    output_interval = 'P1D'
    file_interval = 'P1M'
    include_last = .false.
    output_grid = .false.
    operation = 'mean'
    ml_varlist = 'ps', 'tas', 'cptgzvi', 'rsdt', 'rsut', 'rsutcs', 'rlut',
                 'rlutcs', 'rsds', 'rsdscs', 'rlds', 'rldscs', 'rsus', 'rsuscs',
                 'rlus', 'hfls', 'hfss', 'clt', 'pr', 'prw', 'cllvi', 'clivi',
                 'evspsbl', 'qgvi', 'qrvi', 'qsvi', 'qv2m', 'tauu', 'tauv',
                 'sfcwind', 'uas', 'vas'
/
&output_nml ! 'atm_3d_p1d_ml'
    output_filename = 'ape_from_spinup_short_atm_3d_P1D'
    filename_format = '<output_filename>_<datetime2>'
    filetype = 5
    mode = 1
    output_start = '1979-01-01'
    output_end = '1979-07-03T12:00:00.000'
    output_interval = 'P1D'
    file_interval = 'P1M'
    include_last = .false.
    output_grid = .false.
    operation = 'mean'
    ml_varlist = 'pfull', 'ta', 'rho', 'ua', 'va', 'wa', 'hus', 'cli', 'clw',
                 'qr', 'qg', 'qs', 'phalf', 'rsd', 'rsu', 'rld', 'rlu'
    m_levels = '30...(nlev)'
/

EOF

# Selectively add disturbance to overcome model failure
# ------------------------------------------------

if [[ "$disturbance_command" ]]
then
    echo "disturbing model for start date ${start_date}, using '$disturbance_command'"
    eval "$disturbance_command"
fi

#-----------------------------------------------------------------------------

if [ $mpi_total_procs -lt $((mpi_oce_procs + 1)) ] ; then
   echo "Total task count ($mpi_total_procs) does not fit ocean task count ($mpi_oce_procs)"
   echo "-> check mpi_total_procs and mpi_oce_procs. Exiting"
   check_error 1
   exit 1
fi

#=============================================================================
#
# This section of the run script prepares and starts the model integration.
#
#-----------------------------------------------------------------------------

#-----------------------------------------------------------------------------
# Provide input files
# $Id: format.tmpl 9264 2021-06-21 21:24:57Z m221078 $
#
# [files]

# [files.atmosphere]
atmosphere_dir=/pool/data/ICON/grids/public/mpim

# [files.atmosphere.mapped]
mapped_dir=$atmosphere_dir/0013
ln -s $mapped_dir/icon_grid_0013_R02B04_G.nc icon_grid_G.nc

# [files.atmosphere.mapped.ozone]
ozone_dir=$mapped_dir/ozone/r0002
ln -s $ozone_dir/bc_ozone_ape.nc bc_ozone.nc

# [files.atmosphere.restart]
restart_dir=/work/ka1125/m301160/icon-model/experiments/ape_from_spinup_short/work
ln -snvf $restart_dir/ape_from_spinup_restart_atm_${start_stamp}Z.nc \
    multifile_restart_atm.mfr

# [files.atmosphere.model]
model_dir=/work/ka1125/m301160/icon-model

# [files.atmosphere.model.run]
run_dir=$model_dir/run
ln -snvf $run_dir/dict.iconam.mpim dict.txt

# [files.atmosphere.model.data]
data_dir=$model_dir/data
ln -snvf $data_dir/ECHAM6_CldOptProps_rrtmgp_lw.nc \
    rrtmgp-cloud-optics-coeffs-lw.nc
ln -snvf $data_dir/ECHAM6_CldOptProps_rrtmgp_sw.nc \
    rrtmgp-cloud-optics-coeffs-sw.nc

# [files.atmosphere.model.rrtmgp]
rrtmgp_dir=$model_dir/data
ln -snvf $rrtmgp_dir/rrtmgp-gas-lw-g128.nc coefficients_lw.nc
ln -snvf $rrtmgp_dir/rrtmgp-gas-sw-g112.nc coefficients_sw.nc


# [files.atmosphere.independent]
independent_dir=$atmosphere_dir/common
ln -s $independent_dir/greenhouse_gases/greenhouse_historical_plus.nc \
    bc_greenhouse_gases.nc





#-----------------------------------------------------------------------------
#  get model
#
ls -l ${MODEL}
check_error $? "${MODEL} does not exist?"
#
ldd ${MODEL}
#
#-----------------------------------------------------------------------------
#
# start experiment
#

cp -p ${MODEL} ./icon
export MODEL=./icon

rm -f finish.status

date
${START} ${MODEL}
date

if [ -r finish.status ] ; then
  check_final_status 0 "${START} ${MODEL}"
else
  check_final_status -1 "${START} ${MODEL}"
fi

# Handle restart hand-over

if [ -z "${next_date_orig:-}" ] || true
then
    cp -lrfv ape_from_spinup_restart_atm_${next_stamp}Z.nc /work/ka1125/m301160/icon-model/experiments/ape_from_spinup_short/work
fi
# Clean up our restart

rm -rfv ape_from_spinup_restart_atm_${start_stamp}Z.nc
#
#-----------------------------------------------------------------------------
#
finish_status=`cat finish.status`
finish_status="${finish_status# }"
echo $finish_status
echo "============================"
echo "Script run successfully: $finish_status"
echo "============================"
#-----------------------------------------------------------------------------

# Mark current run as successful in log
echo $(date -u +'%Y-%m-%dT%H:%M:%SZ') ${start_date%:*} ${end_date%:*} ${SLURM_JOBID}  end >> $exp_log_file

cd $SCRIPT_DIR
set +e
status=0

# Update date info for next run
echo $next_date > $start_date_file

if [ $finish_status = "RESTART" ]
then
  (
    echo "restart: submitting 'ape_from_spinup_short.run'"
    sbatch ape_from_spinup_short.run
  ) || status=$?
fi
exit $status

#-----------------------------------------------------------------------------
# vim:ft=sh
#-----------------------------------------------------------------------------
